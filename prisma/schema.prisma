// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator prismaClassGenerator {
  provider = "prisma-class-generator"
}

model Post {
  id        Int       @id @default(dbgenerated("uuid"))
  title     String
  content   String?
  published Boolean   @default(false)
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#now
  createdAt DateTime  @default(now())
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#updatedat
  updatedAt DateTime  @updatedAt
  // https://www.prisma.io/docs/concepts/components/prisma-client/middleware/soft-delete-middleware
  deletedAt DateTime?

  @@map("posts")
}

model User {
  id             String    @id @default(dbgenerated("uuid"))
  name           String
  family         String
  posts          Post[]
  email          String    @unique(map: "email_unique_constraint")
  hashedPassword String
  avatar         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  Admin Admin?

  @@map("users")
}

model Admin {
  id        String   @unique(map: "admin_id_unique_constraint")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Rlationships
  userId String @unique @map("user_id")
  User   User   @relation(references: [id], fields: [userId])
  Files  File[]

  @@id([userId, id])
  @@map("admins")
}

model File {
  id        String   @id
  filename  String   @db.VarChar(500)
  size      Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  adminUserId String   @map("admin_user_id")
  adminId     String   @map("admin_id")
  Admin       Admin    @relation(fields: [adminId, adminUserId], references: [userId, id])
  mimetypeKey String
  Mimetype    Mimetype @relation(fields: [mimetypeKey], references: [key])

  @@map("files")
}

model Mimetype {
  key                   String   @id
  value                 String   @unique(map: "mime_type_value_unique_constraint")
  maximumSizeInMegabyte Int      @db.SmallInt
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relationships
  Files File[]

  @@map("mime_types")
}
