{
    "include": ["src"],
    "compilerOptions": {
        "incremental": true,
        "target": "es2017",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "module": "commonjs",
        "baseUrl": "./",
        "paths": {
            "@you-say/src/*": ["src/*"],
            "@you-say/users": ["./src/packages/users"],
            "@you-say/posts": ["./src/packages/posts"]
        },
        "resolveJsonModule": true,
        "declaration": true,
        "sourceMap": true,
        "outDir": "./dist",
        "removeComments": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": false,
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictBindCallApply": true,
        "strictPropertyInitialization": false,
        "alwaysStrict": true,
        "noFallthroughCasesInSwitch": false,
        "skipLibCheck": true
    }
}
